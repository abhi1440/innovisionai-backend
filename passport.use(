passport.use(
  new GoogleStrategy(
    {
      clientID: process.env.GOOGLE_CLIENT_ID,
      clientSecret: process.env.GOOGLE_CLIENT_SECRET,
      callbackURL: "/auth/google/callback",
    },
    async (accessToken, refreshToken, profile, done) => {
      try {
        // Create user object with explicit username
        const user = {
          username: profile.displayName,  // Make sure this is being set
          email: profile.emails[0].value,
          googleId: profile.id
        };

        // When sending response to frontend, include username
        const token = jwt.sign(
          { 
            userId: user.id,
            username: user.username,  // Explicitly include username in token
            email: user.email 
          },
          process.env.JWT_SECRET
        );

        return done(null, { user, token });
      } catch (error) {
        return done(error, null);
      }
    }
  )
);

// Add this route to send user data after successful Google auth
app.get('/auth/google/success', (req, res) => {
  if (req.user) {
    res.json({
      success: true,
      user: {
        username: req.user.username,
        email: req.user.email
      }
    });
  }
});